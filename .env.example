# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address that receives booking notifications.
# When using onboarding@resend.dev (free/testing), this must be your Resend account email.
BOOKING_RECIPIENT_EMAIL=braintopiacenters@gmail.com

# Optional: override the sender once you have a verified domain (e.g. Braintopia <bookings@yourdomain.com)
# RESEND_FROM_EMAIL=Braintopia <onboarding@resend.dev>
